- const nav_music_id = theme.nav_music.id
- const nav_music_server = theme.nav_music.server
- const nav_music_volume = theme.nav_music.volume
- const default_song_id = theme.nav_music.default_song_id || false
#nav-music
  a#nav-music-hoverTips(onclick='anzhiyu.musicToggle()' accesskey="m") 播放音乐
  #console-music-bg
  meting-js(id=nav_music_id server=nav_music_server type="playlist" mutex="true" preload="none" theme="var(--anzhiyu-main)" data-lrctype="0" order="random" volume=nav_music_volume)
  if default_song_id
    script.
      (function(){
        var defaultSongId = '!{default_song_id}';
        var checkInterval = setInterval(function(){
          var aplayerEl = document.querySelector('#nav-music meting-js');
          if (aplayerEl && aplayerEl.aplayer && aplayerEl.aplayer.list && aplayerEl.aplayer.list.audios.length > 0) {
            clearInterval(checkInterval);
            var audios = aplayerEl.aplayer.list.audios;
            for (var i = 0; i < audios.length; i++) {
              if (audios[i].id == defaultSongId) {
                aplayerEl.aplayer.list.switch(i);
                break;
              }
            }
          }
        }, 500);
      })();
